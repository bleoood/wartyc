local function buildBox(plr)
    -- Root billboard anchored to HRP
    local bbg = Instance.new("BillboardGui")
    bbg.Name             = plr.Name
    bbg.AlwaysOnTop      = true
    bbg.Size             = UDim2.new(4, 0, 5.4, 0)
    bbg.ClipsDescendants = false
    bbg.Enabled          = false
    bbg.Parent           = espGui

    -- Four edge frames that form the box outline
    local function makeEdge()
        local f = Instance.new("Frame")
        f.BorderSizePixel      = 0
        f.BackgroundColor3     = ESP.Box.Color
        f.Parent               = bbg
        return f
    end
    local eLeft   = makeEdge(); eLeft.Size     = UDim2.new(0, 1, 1, 0); eLeft.Position   = UDim2.new(0, 0, 0, 0)
    local eRight  = makeEdge(); eRight.Size    = UDim2.new(0, 1, 1, 0); eRight.Position  = UDim2.new(1, -1, 0, 0)
    local eTop    = makeEdge(); eTop.Size      = UDim2.new(1, 0, 0, 1); eTop.Position    = UDim2.new(0, 0, 0, 0)
    local eBottom = makeEdge(); eBottom.Size   = UDim2.new(1, 0, 0, 1); eBottom.Position = UDim2.new(0, 0, 1, -1)

    -- Info billboard (name / distance / health text) placed to the right of the box
    local infoBbg = Instance.new("BillboardGui")
    infoBbg.Name             = plr.Name .. "_info"
    infoBbg.AlwaysOnTop      = true
    infoBbg.Size             = UDim2.new(3, 0, 0, 60)
    infoBbg.StudsOffset      = Vector3.new(3.8, -3, 0)
    infoBbg.ClipsDescendants = false
    infoBbg.Enabled          = false
    infoBbg.Parent           = espGui

    local function makeLabel(yPos, textSize)
        local lbl = Instance.new("TextLabel")
        lbl.BackgroundTransparency = 1
        lbl.TextStrokeTransparency = 0.6
        lbl.TextStrokeColor3       = Color3.new(0, 0, 0)
        lbl.TextXAlignment         = Enum.TextXAlignment.Left
        lbl.Font                   = Enum.Font.GothamBold
        lbl.TextSize               = textSize or 13
        lbl.Size                   = UDim2.new(1, 0, 0, 18)
        lbl.Position               = UDim2.new(0, 0, 0, yPos)
        lbl.Parent                 = infoBbg
        return lbl
    end

    local nameLabel   = makeLabel(0, 13)
    local distLabel   = makeLabel(18, 11)
    local healthLabel = makeLabel(36, 11)
    nameLabel.Text    = plr.Name

    -- Health bar billboard
    local healthBbg = Instance.new("BillboardGui")
    healthBbg.Name             = plr.Name .. "_hp"
    healthBbg.AlwaysOnTop      = true
    healthBbg.Size             = UDim2.new(4.5, 0, 6, 0)
    healthBbg.ClipsDescendants = false
    healthBbg.Enabled          = false
    healthBbg.Parent           = espGui

    local barBg = Instance.new("Frame")
    barBg.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    barBg.Size             = UDim2.new(0.04, 0, 0.9, 0)
    barBg.Position         = UDim2.new(0, 0, 0.05, 0)
    barBg.BorderSizePixel  = 0
    barBg.Parent           = healthBbg

    local barFill = Instance.new("Frame")
    barFill.BorderSizePixel  = 0
    barFill.BackgroundColor3 = Color3.fromRGB(80, 220, 60)
    barFill.AnchorPoint      = Vector2.new(0, 1)
    barFill.Position         = UDim2.new(0, 0, 1, 0)
    barFill.Size             = UDim2.new(1, 0, 1, 0)
    barFill.Parent           = barBg

    -- Adornee helper
    local function setAdornees(hrpPart)
        bbg.Adornee      = hrpPart
        infoBbg.Adornee  = hrpPart
        healthBbg.Adornee = hrpPart
    end

    if plr.Character then
        local hrpPart = plr.Character:FindFirstChild("HumanoidRootPart")
        if hrpPart then setAdornees(hrpPart) end
    end
    plr.CharacterAdded:Connect(function(char)
        setAdornees(char:WaitForChild("HumanoidRootPart"))
    end)

    -- Update loop
    task.spawn(function()
        while task.wait(0.1) do
            if not Players:FindFirstChild(plr.Name) then
                bbg:Destroy()
                infoBbg:Destroy()
                healthBbg:Destroy()
                return
            end

            local cfg  = ESP.Box
            local char = plr.Character
            local hum  = char and char:FindFirstChildWhichIsA("Humanoid")
            local myHRP = character and character:FindFirstChild("HumanoidRootPart")

            if plr ~= player and char and hum and hum.Health > 0 then
                local hide    = cfg.TeamCheck and plr.TeamColor == player.TeamColor
                local visible = cfg.Enabled and not hide

                -- Box visibility
                bbg.Enabled      = visible
                infoBbg.Enabled  = visible
                healthBbg.Enabled = visible and cfg.Health

                -- Edge colors
                local col = cfg.Color
                eLeft.BackgroundColor3   = col
                eRight.BackgroundColor3  = col
                eTop.BackgroundColor3    = col
                eBottom.BackgroundColor3 = col

                -- Edge visibility (only show when box toggle is on)
                eLeft.Visible   = visible
                eRight.Visible  = visible
                eTop.Visible    = visible
                eBottom.Visible = visible

                -- Name label
                nameLabel.TextColor3 = col
                nameLabel.Visible    = cfg.Name
                nameLabel.Text       = plr.Name

                -- Distance label
                distLabel.TextColor3 = col
                distLabel.Visible    = cfg.Distance
                if cfg.Distance and myHRP then
                    local hrpPart2 = char:FindFirstChild("HumanoidRootPart")
                    if hrpPart2 then
                        local d = math.floor(0.5 + (myHRP.Position - hrpPart2.Position).Magnitude)
                        distLabel.Text = d .. " studs"
                    end
                end

                -- Health
                healthLabel.TextColor3 = col
                if cfg.Health then
                    local pct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                    barFill.Size = UDim2.new(1, 0, pct, 0)
                    -- Gradient green ‚Üí red
                    barFill.BackgroundColor3 = Color3.fromRGB(
                        math.floor(255 * (1 - pct)),
                        math.floor(200 * pct),
                        40
                    )
                    healthLabel.Text    = string.format("HP %d/%d", math.floor(hum.Health), math.floor(hum.MaxHealth))
                    healthLabel.Visible = cfg.HealthType == "Text" or cfg.HealthType == "Both"
                    barBg.Visible       = cfg.HealthType == "Bar"  or cfg.HealthType == "Both"
                else
                    healthLabel.Visible = false
                    barBg.Visible       = false
                end
            else
                bbg.Enabled       = false
                infoBbg.Enabled   = false
                healthBbg.Enabled = false
            end
        end
    end)
end

