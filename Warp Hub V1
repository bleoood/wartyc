local function buildTracer(plr)
    local line = Instance.new("Frame")
    line.Name             = plr.Name
    line.AnchorPoint      = Vector2.new(0.5, 0.5)
    line.BorderSizePixel  = 0
    line.Visible          = false
    line.Parent           = tracerGui

    RunService.RenderStepped:Connect(function()
        if not Players:FindFirstChild(plr.Name) then
            line:Destroy() return
        end

        local cfg  = ESP.Tracers
        local char = plr.Character
        local hum  = char and char:FindFirstChildWhichIsA("Humanoid")

        if plr ~= player and char and hum and hum.Health > 0 then
            local hrpPart = char:FindFirstChild("HumanoidRootPart")
            if not hrpPart then line.Visible = false return end

            local screenPt, onScreen = camera:WorldToViewportPoint(hrpPart.Position)
            if not onScreen then line.Visible = false return end

            local dist    = math.max(1, (camera.CFrame.Position - hrpPart.Position).Magnitude)
            local target  = Vector2.new(screenPt.X, screenPt.Y + (2500 / dist))
            local origin  = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
            local mid     = (origin + target) / 2
            local length  = (origin - target).Magnitude
            local angle   = math.deg(math.atan2(target.Y - origin.Y, target.X - origin.X))

            local hide    = cfg.TeamCheck and plr.TeamColor == player.TeamColor
            line.Visible          = cfg.Enabled and not hide
            line.BackgroundColor3 = cfg.TeamColor and plr.TeamColor.Color or cfg.Color
            line.Position         = UDim2.fromOffset(mid.X, mid.Y)
            line.Size             = UDim2.fromOffset(length, 1)
            line.Rotation         = angle
        else
            line.Visible = false
        end
    end)
end

