----------------------------------------------------------------
-- KEYBINDS
----------------------------------------------------------------
UserInputService.InputBegan:Connect(function(i, gp)
	if gp then return end
	if i.KeyCode == Enum.KeyCode.F then
		VEHICLE_ESP = not VEHICLE_ESP
		if not VEHICLE_ESP then clearVehicleHighlights() end
	elseif i.KeyCode == Enum.KeyCode.G then
		local nearest, dist = nil, math.huge
		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
				local d = (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
				if d < dist then dist = d; nearest = p end
			end
		end
		spectate(nearest)
	elseif i.KeyCode == Enum.KeyCode.H then
		camera.CameraSubject = character:FindFirstChildWhichIsA("Humanoid")
	end
end)
