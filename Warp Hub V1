-- AIMBOT HELPERS
----------------------------------------------------------------
local function isVisible(pos)
    if not AIMBOT.WallCheck then return true end
    local obscuring = camera:GetPartsObscuringTarget({pos}, {camera, character})
    return #obscuring == 0
end

local function getAimbotTarget()
    local bestMag = AIMBOT.Fov
    local target  = nil
    local mouse   = UserInputService:GetMouseLocation()

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == player then continue end
        if AIMBOT.TeamCheck and plr.Team == player.Team then continue end
        local char2 = plr.Character
        local part  = char2 and char2:FindFirstChild(AIMBOT.AimPart)
        local hum   = char2 and char2:FindFirstChildWhichIsA("Humanoid")
        if not part or not hum or hum.Health <= 0 then continue end

        local screenPt, onScreen = camera:WorldToViewportPoint(part.Position)
        if not onScreen then continue end

        local mag = (Vector2.new(screenPt.X, screenPt.Y) - mouse).Magnitude
        if mag < bestMag and isVisible(part.Position) then
            bestMag = mag
            target  = plr
        end
    end
    return target
end

local function stepAimbot()
    local target = getAimbotTarget()
    if not target then return end
    local part = target.Character and target.Character:FindFirstChild(AIMBOT.AimPart)
    if not part then return end

    local smooth = math.max(AIMBOT.Smoothing * 0.01, 0.001)
    local dist   = (hrp.Position - part.Position).Magnitude
    local scale  = math.max(dist / 10, 1)
    local lookAt = camera.CFrame:PointToWorldSpace(
        Vector3.new(0, 0, -smooth * scale)
    ):Lerp(part.Position, 0.015)
    camera.CFrame = CFrame.lookAt(camera.CFrame.Position, lookAt)
end

-- Aimbot + FOV circle update on RenderStepped
RunService.RenderStepped:Connect(function()
    -- Aimbot
    if AIMBOT.Enabled and AIMBOT.Active then
        stepAimbot()
    end

    -- FOV circle
    local mouse = UserInputService:GetMouseLocation()
    fovFrame.Position = UDim2.fromOffset(mouse.X, mouse.Y)
    local diameter = AIMBOT.Fov * 2
    fovFrame.Size     = UDim2.fromOffset(diameter, diameter)
    fovFrame.Visible  = AIMBOT.ShowFov and AIMBOT.Enabled
    fovStroke.Color   = AIMBOT.FovColor
    fovStroke.Thickness = AIMBOT.Thickness
end)

