local function addOutline(plr)
	local highlight = Instance.new("Highlight")
	highlight.Parent = outlineContainer
	highlight.Name = plr.Name
	highlight.Enabled = false

	if plr.Character then highlight.Adornee = plr.Character end
	plr.CharacterAdded:Connect(function(char) highlight.Adornee = char end)

	task.spawn(function()
		while task.wait(0.1) do
			if not game:GetService("Players"):FindFirstChild(plr.Name) then
				highlight:Destroy()
				break
			end

			local char = plr.Character
			local hum = char and char:FindFirstChildWhichIsA("Humanoid")
			if plr ~= player and char and hum and hum.Health > 0 then
				local cfg = ESP.Outlines
				if cfg.Enabled then
					if cfg.TeamCheck and plr.TeamColor == player.TeamColor then
						highlight.Enabled = false
					else
						highlight.Enabled = true
					end
				else
					highlight.Enabled = false
				end

				highlight.DepthMode = cfg.AlwaysOnTop
					and Enum.HighlightDepthMode.AlwaysOnTop
					or Enum.HighlightDepthMode.Occluded

				highlight.FillColor = cfg.TeamColor and plr.TeamColor.Color or cfg.FillColor
				highlight.FillTransparency = cfg.FillTransparency
				highlight.OutlineColor = cfg.OutlineColor
				highlight.OutlineTransparency = cfg.OutlineTransparency
			else
				highlight.Enabled = false
			end
		end
	end)
end

