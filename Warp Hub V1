local function getDrones()
	local list = {}
	for _, d in ipairs(droneFolder:GetChildren()) do
		if d:IsA("Model") and d.Name:lower():find("crasheddrone") then
			table.insert(list, d)
		end
	end
	return list
end

local function interactDrone(drone)
	local pp = drone:FindFirstChild("PromptPart", true)
	if not pp then return end
	local prompt = pp:FindFirstChildWhichIsA("ProximityPrompt", true)
	if not prompt then return end
	hrp.CFrame = pp.CFrame + Vector3.new(0, 3, 0)
	task.wait(0.3)
	pcall(function() fireproximityprompt(prompt) end)
	local t0 = tick()
	repeat task.wait(0.2)
	until not prompt.Parent or not prompt.Enabled or tick() - t0 > 15
end

local function deliverDrone()
	hrp.CFrame = droneReturnCFrame
	local hum = character:FindFirstChildWhichIsA("Humanoid")
	if not hum then return end
	local duration = math.random(10, 15)
	local start = tick()
	local lastJump = 0
	while tick() - start < duration do
		if tick() - lastJump >= 2 then
			hum:ChangeState(Enum.HumanoidStateType.Jumping)
			lastJump = tick()
		end
		task.wait(0.1)
	end
end

