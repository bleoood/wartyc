-- TYCOON AUTO BUY
----------------------------------------------------------------
local function getCash()
	local stats = player:FindFirstChild("leaderstats")
	if not stats then return 0 end
	local cash = stats:FindFirstChild("Cash")
	return cash and cash.Value or 0
end

local function getPlayerTycoon()
	local tycoonsFolder = workspace:FindFirstChild("Tycoon") or workspace:FindFirstChild("Tycoons")
	if not tycoonsFolder then return end
	local tycoons = tycoonsFolder:FindFirstChild("Tycoons") or tycoonsFolder
	for _, tycoon in ipairs(tycoons:GetChildren()) do
		if tycoon.Name == player.Team.Name then return tycoon end
	end
end

local function getButtons(tycoon)
	local buttonsFolder = tycoon:FindFirstChild("UnpurchasedButtons")
	if not buttonsFolder then return {} end
	local list = {}
	for _, btn in ipairs(buttonsFolder:GetChildren()) do
		if btn:IsA("Model") or btn:IsA("Part") then
			local typeAttr = btn:GetAttribute("ButtonType")
			local price = btn:GetAttribute("Price")
			if typeAttr == "Cash" and price then
				table.insert(list, { instance = btn, price = price })
			end
		end
	end
	return list
end

local function getButtonCFrame(btn)
	if btn:IsA("BasePart") then
		return btn.CFrame
	elseif btn:IsA("Model") then
		if btn.PrimaryPart then return btn.PrimaryPart.CFrame end
		local part = btn:FindFirstChildWhichIsA("BasePart")
		if part then return part.CFrame end
	end
end

local function buyButton(btn)
	local cf = getButtonCFrame(btn)
	if not cf then return end
	hrp.CFrame = cf + Vector3.new(0, 3, 0)
	task.wait(0.25)
end

----------------------------------------------------------------
-- GENERIC COLLECTOR
----------------------------------------------------------------
local function collectModel(model)
	local promptPart = model:FindFirstChild("PromptPart", true)
	if not promptPart then return end
	local prompt = promptPart:FindFirstChildWhichIsA("ProximityPrompt", true)
	if not prompt or not prompt.Enabled then return end
	tweenTo(promptPart.CFrame)
	task.wait(0.25)
	hrp.CFrame = promptPart.CFrame + Vector3.new(0, 3, 0)
	pcall(function() fireproximityprompt(prompt) end)
	local t0 = tick()
	repeat task.wait(0.2)
	until not prompt.Parent or not prompt.Enabled or tick() - t0 > 10
end

