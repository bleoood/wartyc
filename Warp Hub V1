local vehicleHighlights = {}

local function clearVehicleHighlights()
	for _, h in pairs(vehicleHighlights) do
		if h then h:Destroy() end
	end
	vehicleHighlights = {}
end

local function getSeat(model)
	for _, v in ipairs(model:GetDescendants()) do
		if v:IsA("VehicleSeat") or v:IsA("Seat") then return v end
	end
end

local function getDriver(model)
	local seat = getSeat(model)
	if not seat or not seat.Occupant then return end
	return Players:GetPlayerFromCharacter(seat.Occupant.Parent)
end

local function applyVehicleHighlight(model)
	if vehicleHighlights[model] then return end
	local h = Instance.new("Highlight")
	h.FillTransparency = 0.4
	h.Parent = model
	vehicleHighlights[model] = h
end

local function getVehicles()
	local list = {}
	for fname in pairs(vehicleFolderNames) do
		local folder = GS:FindFirstChild(fname)
		if folder then
			for _, m in ipairs(folder:GetChildren()) do
				if m:IsA("Model") then table.insert(list, m) end
			end
		end
	end
	return list
end

