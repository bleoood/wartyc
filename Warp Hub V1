local function getCash()
    local stats = player:FindFirstChild("leaderstats")
    return stats and stats:FindFirstChild("Cash") and stats.Cash.Value or 0
end

local function getTycoonRoot()
    local folder = workspace:FindFirstChild("Tycoon")
    folder = folder and (folder:FindFirstChild("Tycoons") or folder)
    if not folder then return end
    for _, t in ipairs(folder:GetChildren()) do
        if t.Name == player.Team.Name then return t end
    end
end

local function getButtons(tycoon)
    local btns = tycoon:FindFirstChild("UnpurchasedButtons")
    if not btns then return {} end
    local list = {}
    for _, btn in ipairs(btns:GetChildren()) do
        local price = btn:GetAttribute("Price")
        if btn:GetAttribute("ButtonType") == "Cash" and price then
            table.insert(list, {instance = btn, price = price})
        end
    end
    return list
end

local function getButtonCFrame(btn)
    if btn:IsA("BasePart") then return btn.CFrame end
    if btn:IsA("Model") then
        if btn.PrimaryPart then return btn.PrimaryPart.CFrame end
        local p = btn:FindFirstChildWhichIsA("BasePart")
        return p and p.CFrame
    end
end

----------------------------------------------------------------
-- MOVEMENT
----------------------------------------------------------------
local function tweenTo(cf)
    if MODE == "Instant" then
        hrp.CFrame = cf
        return
    end
    local dist = (hrp.Position - cf.Position).Magnitude
    local t    = math.clamp(dist / 120, 0.25, 6)
    local tw   = TweenService:Create(hrp, TweenInfo.new(t, Enum.EasingStyle.Linear), {CFrame = cf})
    tw:Play()
    tw.Completed:Wait()
end

----------------------------------------------------------------
-- TYCOON AUTO BUY LOOP
----------------------------------------------------------------
task.spawn(function()
    while true do
        if AUTO_BUY and player.Team then
            local root = getTycoonRoot()
            if root then
                local cash    = getCash()
                local buttons = getButtons(root)
                table.sort(buttons, function(a, b) return a.price < b.price end)
                for _, data in ipairs(buttons) do
                    if not AUTO_BUY then break end
                    if cash >= data.price then
                        local cf = getButtonCFrame(data.instance)
                        if cf then
                            hrp.CFrame = cf + Vector3.new(0, 3, 0)
                            task.wait(0.3)
                            cash = getCash()
                        end
                    end
                end
            end
        end
        task.wait(1)
    end
end)

----------------------------------------------------------------
-- VEHICLE ESP LOOP
----------------------------------------------------------------
task.spawn(function()
    while true do
        if VEHICLE_ESP then
            for _, m in ipairs(getVehicles()) do
                local dist   = (m:GetPivot().Position - hrp.Position).Magnitude
                if dist > MAX_DISTANCE then continue end
                local driver = getDriver(m)
                if IGNORE_EMPTY and not driver then continue end
                if IGNORE_SAME and driver and driver.Team == player.Team then continue end
                applyVehicleHighlight(m)
            end
        else
            clearVehicleHighlights()
        end
        task.wait(1)
    end
end)

