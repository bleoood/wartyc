local function addTracer(plr)
	local tracer = Instance.new("Frame", tracerContainer)
	tracer.Name = plr.Name
	tracer.Active = false
	tracer.AnchorPoint = Vector2.new(0.5, 0.5)
	tracer.Visible = false
	tracer.BorderSizePixel = 0

	RunService.RenderStepped:Connect(function()
		local char = plr.Character
		local hum = char and char:FindFirstChildWhichIsA("Humanoid")

		if not game:GetService("Players"):FindFirstChild(plr.Name) then
			tracer:Destroy()
			return
		end

		if plr ~= player and char and hum and hum.Health > 0 then
			local cfg = ESP.Tracers
			local hrpPart = char:FindFirstChild("HumanoidRootPart")
			if not hrpPart then tracer.Visible = false return end

			local screenPoint, onScreen = camera:WorldToScreenPoint(hrpPart.Position)
			if not onScreen then tracer.Visible = false return end

			local distance = math.floor(0.5 + (camera.CFrame.Position - hrpPart.Position).Magnitude)
			local targetPoint = Vector2.new(screenPoint.X, screenPoint.Y + (2500 / distance))
			local origin = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
			local midpoint = (origin + targetPoint) / 2
			local length = (origin - targetPoint).Magnitude
			local angle = math.deg(math.atan2(targetPoint.Y - origin.Y, targetPoint.X - origin.X))

			local hide = cfg.TeamCheck and plr.TeamColor == player.TeamColor
			tracer.Visible = cfg.Enabled and not hide
			tracer.BackgroundColor3 = cfg.TeamColor and plr.TeamColor.Color or cfg.Color
			tracer.Position = UDim2.new(0, midpoint.X, 0, midpoint.Y)
			tracer.Size = UDim2.new(0, length, 0, 2)
			tracer.Rotation = angle
		else
			tracer.Visible = false
		end
	end)
end

local function initPlayerESP(plr)
	addOutline(plr)
	addBox(plr)
	addTracer(plr)
end

for _, plr in ipairs(Players:GetPlayers()) do
	if plr ~= player then initPlayerESP(plr) end
end
Players.PlayerAdded:Connect(function(plr)
	initPlayerESP(plr)
