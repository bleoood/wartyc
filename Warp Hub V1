-- BACKGROUND LOOPS
----------------------------------------------------------------
task.spawn(function()
	while true do
		if AUTO_BUY and player.Team then
			local tycoon = getPlayerTycoon()
			if tycoon then
				local cash = getCash()
				local buttons = getButtons(tycoon)
				table.sort(buttons, function(a, b) return a.price < b.price end)
				for _, data in ipairs(buttons) do
					if not AUTO_BUY then break end
					if cash >= data.price then
						buyButton(data.instance)
						task.wait(0.4)
						cash = getCash()
					end
				end
			end
		end
		task.wait(1)
	end
end)

task.spawn(function()
	while true do
		if VEHICLE_ESP then
			for _, m in ipairs(getVehicles()) do
				local dist = (m:GetPivot().Position - hrp.Position).Magnitude
				if dist > MAX_DISTANCE then continue end
				local driver = getDriver(m)
				if IGNORE_EMPTY and not driver then continue end
				if IGNORE_SAME_TEAM and driver and driver.Team == player.Team then continue end
				applyVehicleHighlight(m)
			end
		else
			clearVehicleHighlights()
		end
		task.wait(1)
	end
end)

RunService.RenderStepped:Connect(function()
	if not VEHICLE_ESP then return end
	local t = tick()
	local color = Color3.fromHSV((t % 5) / 5, 1, 1)
	for _, h in pairs(vehicleHighlights) do
		if h then
			h.FillColor = color
			h.OutlineColor = color
		end
	end
end)

task.spawn(function()
	while true do
		if CRATE_FARM then
			for _, c in ipairs(getCrates()) do
				if not CRATE_FARM then break end
				collectModel(c)
			end
		end
		if OIL_FARM then
			for _, o in ipairs(getOilBarrels()) do
				if not OIL_FARM then break end
				collectModel(o)
			end
		end
		task.wait(2)
	end
end)

task.spawn(function()
	while true do
		if DRONE_FARM then
			for _, d in ipairs(getDrones()) do
				if not DRONE_FARM then break end
				interactDrone(d)
				deliverDrone()
			end
		end
		task.wait(2)
	end
end)

