end

local function collectModel(model)
    local pp     = model:FindFirstChild("PromptPart", true)
    if not pp then return end
    local prompt = pp:FindFirstChildWhichIsA("ProximityPrompt", true)
    if not prompt or not prompt.Enabled then return end
    tweenTo(pp.CFrame)
    task.wait(0.3)
    hrp.CFrame = pp.CFrame + Vector3.new(0, 3, 0)
    pcall(function() fireproximityprompt(prompt) end)
    local t0 = tick()
    repeat task.wait(0.2)
    until not prompt.Parent or not prompt.Enabled or tick() - t0 > 10
    local plane = getResourceCollector()
    if plane then tweenTo(plane.CFrame + Vector3.new(0, 3, 0)) end
end

local function interactDrone(drone)
    local pp     = drone:FindFirstChild("PromptPart", true)
    if not pp then return end
    local prompt = pp:FindFirstChildWhichIsA("ProximityPrompt", true)
    if not prompt then return end
    hrp.CFrame = pp.CFrame + Vector3.new(0, 3, 0)
    task.wait(0.3)
    pcall(function() fireproximityprompt(prompt) end)
    local t0 = tick()
    repeat task.wait(0.2)
    until not prompt.Parent or not prompt.Enabled or tick() - t0 > 15
end

local function deliverDrone()
    local col = getDroneCollector()
    if col then hrp.CFrame = col.CFrame + Vector3.new(0, 3, 0) end
    local hum     = character and character:FindFirstChildWhichIsA("Humanoid")
    if not hum then return end
    local finish  = tick() + math.random(10, 15)
    local lastJump = 0
    while tick() < finish do
        if tick() - lastJump >= 2 then
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
            lastJump = tick()
        end
        task.wait(0.1)
    end
end

task.spawn(function()
    while true do
        if CRATE_FARM then
            for _, c in ipairs(crateFolder:GetChildren()) do
                if not CRATE_FARM then break end
                if c:IsA("Model") then collectModel(c) end
            end
        end
        if OIL_FARM then
            for _, o in ipairs(oilFolder:GetChildren()) do
                if not OIL_FARM then break end
                if o:IsA("Model") then collectModel(o) end
            end
        end
        task.wait(2)
    end
end)

task.spawn(function()
    while true do
        if DRONE_FARM then
            for _, d in ipairs(droneFolder:GetChildren()) do
                if not DRONE_FARM then break end
                if d:IsA("Model") and d.Name:lower():find("crasheddrone") then
