local function buildOutline(plr)
    local hl = Instance.new("Highlight")
    hl.Name    = plr.Name
    hl.Enabled = false
    hl.Parent  = outlineGui

    local function setAdornee(char)
        hl.Adornee = char
    end
    if plr.Character then setAdornee(plr.Character) end
    plr.CharacterAdded:Connect(setAdornee)

    task.spawn(function()
        while task.wait(0.1) do
            if not Players:FindFirstChild(plr.Name) then
                hl:Destroy() return
            end
            local cfg  = ESP.Outlines
            local char = plr.Character
            local hum  = char and char:FindFirstChildWhichIsA("Humanoid")

            if char and hum and hum.Health > 0 and plr ~= player then
                local hide = cfg.TeamCheck and plr.TeamColor == player.TeamColor
                hl.Enabled  = cfg.Enabled and not hide
                hl.DepthMode = cfg.AlwaysOnTop
                    and Enum.HighlightDepthMode.AlwaysOnTop
                    or  Enum.HighlightDepthMode.Occluded
                hl.FillColor            = cfg.TeamColor and plr.TeamColor.Color or cfg.FillColor
                hl.FillTransparency     = cfg.FillTransparency
                hl.OutlineColor         = cfg.OutlineColor
                hl.OutlineTransparency  = cfg.OutlineTransparency
            else
                hl.Enabled = false
            end
        end
    end)
end

